# ── Maven build output ────────────────────────────────────────
target/
*.class
*.jar
!.mvn/wrapper/maven-wrapper.jar
*.war
*.ear

# ── Runtime data (never commit) ───────────────────────────────
minicloud-data/**
!minicloud-data/**/.gitkeep
*.mv.db
*.trace.db
*.lock.db

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/

# ── IDEs ──────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
.classpath
.project
.settings/
*.swp
*.swo

# ── OS junk ───────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Spring Boot devtools restart file ─────────────────────────
.reloadtrigger

# ── Local config overrides ────────────────────────────────────
config/
application-local.properties
application-local.yml
